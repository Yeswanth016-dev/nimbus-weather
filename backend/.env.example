# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb://127.0.0.1:27017/nimbus_weather

# OpenWeatherMap API (https://openweathermap.org/api)
OPENWEATHER_API_KEY=your_openweathermap_api_key_here

# YouTube Data API v3 (optional, for travel videos) https://console.cloud.google.com
YOUTUBE_API_KEY=your_youtube_api_key_here

# Optional: enables genuine LLM-generated advice on the AI Weather Advisor card.
# If omitted, a rule-based advice generator is used instead (no external call).
ANTHROPIC_API_KEY=

# Allowed origin for CORS (frontend URL)
CLIENT_ORIGIN=http://localhost:5173
